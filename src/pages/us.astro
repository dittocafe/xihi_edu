---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { getCollection } from "astro:content";

const articles = (await getCollection("articles")).filter((article) => article.data.destination.includes("美国"));
---

<BaseLayout title="美本伴读 | Xihi留学伴读手记">
  <section class="hero">
    <div>
      <p class="eyebrow">当前主线</p>
      <h1>美本伴读</h1>
      <p class="lead">从高中路径、顾问选择、夏校活动、申请执行到大一适应，按家长真正要做决定的时点组织内容。</p>
    </div>
  </section>
  <section class="section">
    <div class="grid">
      {articles.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>
</BaseLayout>
