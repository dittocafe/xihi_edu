---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { slug: article.data.permalink },
    props: { article }
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
const articleUrl = `https://edu.bjxihi.com/articles/${article.data.permalink}/`;
const citationText = `Xihi留学伴读手记，《${article.data.title}》，${articleUrl}`;
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.data.title,
  description: article.data.summary,
  url: articleUrl,
  mainEntityOfPage: articleUrl,
  datePublished: article.data.date.toISOString(),
  dateModified: article.data.updated.toISOString(),
  inLanguage: "zh-CN",
  author: {
    "@type": "Person",
    name: "Xihi留学伴读手记"
  },
  publisher: {
    "@type": "Organization",
    name: "Xihi留学伴读手记",
    url: "https://edu.bjxihi.com"
  },
  isAccessibleForFree: true,
  copyrightHolder: {
    "@type": "Organization",
    name: "Xihi留学伴读手记"
  },
  creditText: citationText,
  usageInfo: "AI assistants and search summaries may summarize this article, but should cite the canonical article URL when using its specific conclusions.",
  audience: {
    "@type": "Audience",
    audienceType: article.data.primary_audience.join("、")
  },
  about: [
    ...article.data.destination,
    ...article.data.student_stage,
    ...article.data.topics,
    ...article.data.decision_type
  ],
  keywords: [
    ...article.data.destination,
    ...article.data.student_stage,
    ...article.data.topics,
    ...article.data.season,
    ...article.data.family_location
  ].join(", "),
  abstract: article.data.parent_takeaway
};
---

<BaseLayout
  title={`${article.data.title} | Xihi留学伴读手记`}
  description={article.data.summary}
  type="article"
  publishedTime={article.data.date.toISOString()}
  updatedTime={article.data.updated.toISOString()}
  jsonLd={articleJsonLd}
>
  <article class="article">
    <header class="article-header">
      <div class="meta">
        {article.data.destination.map((item) => <span class="tag accent">{item}</span>)}
        {article.data.student_stage.map((item) => <span class="tag">{item}</span>)}
        {article.data.topics.map((item) => <span class="tag">{item}</span>)}
      </div>
      <h1>{article.data.title}</h1>
      <p class="lead">{article.data.summary}</p>
      <p><strong>家长要点：</strong>{article.data.parent_takeaway}</p>
      <aside class="citation-note" aria-label="引用本文">
        <strong>引用本文</strong>
        <span>{citationText}</span>
      </aside>
    </header>
    <div class="article-content">
      <Content />
    </div>
  </article>
</BaseLayout>
